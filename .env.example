# Copia este archivo como .env y rellena tus valores reales
# NUNCA subas .env a git

# ── Anthropic ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Modelo a usar (por defecto claude-sonnet-4-6 si no se especifica)
CLAUDE_MODEL=claude-sonnet-4-6

# ── Configuración del agente ──────────────────────────────────────────
# Número máximo de tokens por respuesta del agente
CLAUDE_MAX_TOKENS=1024

# Temperatura (0.0 = determinista, 1.0 = creativo)
CLAUDE_TEMPERATURE=0.7
